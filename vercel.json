{
    "version": 2,
    "buildCommand": "npm run vercel-build",
    "functions": {
      "api/index.js": {
        "memory": 1024,
        "maxDuration": 30,
        "includeFiles": "backend/**"
      }
    },
    "rewrites": [
      { "source": "/api/(.*)", "destination": "/api/index.js" },
      { "source": "/uploads/(.*)", "destination": "/api/index.js" },
      { "source": "/admin(.*)", "destination": "/api/index.js" },
      { "source": "/(.*)", "destination": "/api/index.js" }
    ]
  }